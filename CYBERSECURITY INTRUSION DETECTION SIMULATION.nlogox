<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[;; ============================================================
;; ADVANCED CYBERSECURITY INTRUSION DETECTION SIMULATION
;; Agent-Based Model | NetLogo
;; ============================================================

globals [
  attacks-launched
  attacks-blocked
  attacks-breached
  tick-counter
  suspicious-activity
  current-threat-level
  bot-traffic
  hacker-traffic
  worm-traffic
  ids-alerts
  breach-events
]

breed [nodes node]
breed [attackers attacker]
breed [defenders defender]

nodes-own [
  node-state
  recovery-timer
  is-server?
]

attackers-own [
  target-node
  attack-cooldown
  attacker-type
]

defenders-own [
  patrol-target
  defend-cooldown
]

;; ============================================================
;; SETUP
;; ============================================================

to setup
  clear-all
  clear-output
  set attacks-launched 0
  set attacks-blocked 0
  set attacks-breached 0
  set tick-counter 0
  set suspicious-activity 0
  set current-threat-level 0
  set bot-traffic 0
  set hacker-traffic 0
  set worm-traffic 0
  set ids-alerts 0
  set breach-events 0
  setup-nodes
  setup-links
  setup-attackers
  setup-defenders
  reset-ticks
end

to setup-nodes
  create-nodes 1 [
    set is-server? true
    set node-state "normal"
    set shape "box"
    set color white
    set size 3
    setxy 0 0
    set label "SERVER"
    set label-color yellow
  ]
  create-nodes 6 [
    set is-server? false
    set node-state "normal"
    set shape "circle"
    set color sky
    set size 1.8
    set recovery-timer 0
    let angle (who - 1) * 60
    setxy (8 * sin angle) (8 * cos angle)
    set label who
    set label-color white
  ]
  create-nodes 10 [
    set is-server? false
    set node-state "normal"
    set shape "circle"
    set color sky
    set size 1.5
    set recovery-timer 0
    let angle (who - 7) * 36
    setxy (15 * sin angle) (15 * cos angle)
    set label who
    set label-color white
  ]
end

to setup-links
  ask nodes with [not is-server? and xcor ^ 2 + ycor ^ 2 > 100] [
    let me self
    let closest min-one-of (nodes with [not is-server? and xcor ^ 2 + ycor ^ 2 < 100]) [distance me]
    if closest != nobody [create-link-with closest]
  ]
  ask nodes with [not is-server? and xcor ^ 2 + ycor ^ 2 < 100] [
    create-link-with node 0
  ]
  ask nodes with [xcor ^ 2 + ycor ^ 2 > 100] [
    if random 100 < 30 [
      let me self
      let partner one-of (nodes with [self != me and xcor ^ 2 + ycor ^ 2 > 100])
      if partner != nobody [
        if not link-neighbor? partner [create-link-with partner]
      ]
    ]
  ]
  ask links [set color gray - 3]
end

to setup-attackers
  create-attackers num-attackers [
    set shape "x"
    set color red
    set size 1.8
    set attack-cooldown 0
    set target-node nobody
    set attacker-type one-of ["bot" "hacker" "worm"]
    let edge random 4
    if edge = 0 [setxy (random 40 - 20) 20]
    if edge = 1 [setxy (random 40 - 20) -20]
    if edge = 2 [setxy 20 (random 40 - 20)]
    if edge = 3 [setxy -20 (random 40 - 20)]
    set label attacker-type
    set label-color orange
  ]
end

to setup-defenders
  create-defenders num-defenders [
    set shape "arrow"
    set color green
    set size 1.8
    set defend-cooldown 0
    let start-node one-of (nodes with [not is-server? and xcor ^ 2 + ycor ^ 2 < 100])
    if start-node != nobody [
      setxy [xcor] of start-node [ycor] of start-node
    ]
    set label "DEF"
    set label-color lime
  ]
end

;; ============================================================
;; MAIN LOOP
;; ============================================================

to go
  set tick-counter ticks
  attacker-behavior
  defender-behavior
  node-recovery
  update-node-colors
  if current-threat-level > 0 [
    set current-threat-level current-threat-level - 0.2
  ]
  tick
end

;; ============================================================
;; ATTACKER BEHAVIOR
;; ============================================================

to attacker-behavior
  ask attackers [
    ifelse attack-cooldown > 0 [
      set attack-cooldown attack-cooldown - 1
    ][
      if target-node = nobody [
        set target-node one-of (nodes with [node-state = "normal" and not is-server?])
      ]
      ifelse target-node != nobody [
        face target-node
        if distance target-node > 1 [fd move-speed]
        if distance target-node < 1.5 [
          set attacks-launched attacks-launched + 1
          launch-attack target-node
          set target-node nobody
          set attack-cooldown (50 - attack-rate * 4)
        ]
      ][
        rt random 60 - 30
        fd move-speed
      ]
    ]
  ]
end

to launch-attack [target]
  let detected? false
  let blocked-by-fw? false
  let threat-score 1

  if attacker-type = "bot" [
    set threat-score 1
    set bot-traffic bot-traffic + 1
  ]
  if attacker-type = "hacker" [
    set threat-score 3
    set hacker-traffic hacker-traffic + 1
  ]
  if attacker-type = "worm" [
    set threat-score 5
    set worm-traffic worm-traffic + 1
  ]

  set suspicious-activity suspicious-activity + threat-score
  set current-threat-level current-threat-level + threat-score

  output-print (word "[TICK " ticks "] " attacker-type " targeting Node " [who] of target)

  if ids-enabled? [
    if random 100 < ids-accuracy [
      set detected? true
    ]
  ]
  if firewall-enabled? [
    if random 100 < 60 [
      set blocked-by-fw? true
    ]
  ]

  ifelse detected? or blocked-by-fw? [
    set attacks-blocked attacks-blocked + 1
    set ids-alerts ids-alerts + 1
    ask target [
      if node-state = "normal" [
        set node-state "quarantined"
        set recovery-timer 80
        set label "IDS ALERT"
        set label-color red
      ]
    ]
    output-print (word "BLOCKED: Attack stopped on Node " [who] of target)
  ][
    set attacks-breached attacks-breached + 1
    set breach-events breach-events + 1
    ask target [
      set node-state "compromised"
      set recovery-timer 120
      set label "BREACHED"
      set label-color orange
    ]
    output-print (word "CRITICAL: Node " [who] of target " COMPROMISED")
    if attacker-type = "worm" [spread-worm target]
  ]
end

to spread-worm [origin]
  ask origin [
    ask link-neighbors [
      if node-state = "normal" and not is-server? [
        if random 100 < 35 [
          set node-state "compromised"
          set recovery-timer 100
          set attacks-breached attacks-breached + 1
          set breach-events breach-events + 1
          set label "WORM"
          set label-color red
          output-print (word "WORM spread to Node " who)
        ]
      ]
    ]
  ]
end

;; ============================================================
;; DEFENDER BEHAVIOR
;; ============================================================

to defender-behavior
  ask defenders [
    ifelse defend-cooldown > 0 [
      set defend-cooldown defend-cooldown - 1
    ][
      let threat one-of (nodes with [node-state = "compromised"])
      ifelse threat != nobody [
        face threat
        if distance threat > 1 [fd 1.5]
        if distance threat < 1.5 [
          ask threat [
            set node-state "quarantined"
            set recovery-timer 60
            set label "SECURED"
            set label-color lime
          ]
          output-print (word "DEFENDER secured Node " [who] of threat)
          set defend-cooldown 40
        ]
      ][
        if patrol-target = nobody
        or not is-agent? patrol-target
        or distance patrol-target < 1 [
          set patrol-target one-of (nodes with [is-server? = false])
        ]
        face patrol-target
        fd 0.8
      ]
    ]
  ]
end

;; ============================================================
;; NODE RECOVERY
;; ============================================================

to node-recovery
  ask nodes [
    if (node-state = "compromised" or node-state = "quarantined") and recovery-timer > 0 [
      set recovery-timer recovery-timer - 1
      if recovery-timer = 0 [
        set node-state "normal"
        ifelse is-server? [
          set label "SERVER"
          set label-color yellow
        ][
          set label who
          set label-color white
        ]
      ]
    ]
  ]
end

;; ============================================================
;; UPDATE COLORS
;; ============================================================

to update-node-colors
  ask nodes [
    if is-server? [set color white]
    if not is-server? [
      if node-state = "normal"      [set color sky]
      if node-state = "compromised" [set color orange]
      if node-state = "quarantined" [set color violet]
    ]
  ]
end

;; ============================================================
;; REPORTERS
;; ============================================================

to-report detection-rate
  ifelse attacks-launched > 0 [
    report (attacks-blocked / attacks-launched) * 100
  ][
    report 0
  ]
end

to-report network-health
  let total-nodes count nodes
  let safe-nodes count nodes with [node-state = "normal"]
  report (safe-nodes / total-nodes) * 100
end

to-report compromised-count
  report count nodes with [node-state = "compromised"]
end

to-report quarantined-count
  report count nodes with [node-state = "quarantined"]
end

to-report threat-level
  report current-threat-level
end

to-report total-ids-alerts
  report ids-alerts
end

to-report total-breaches
  report breach-events
end]]></code>
  <widgets>
    <view x="370" wrappingAllowedX="true" y="100" frameRate="30.0" minPycor="-16" height="425" showTickCounter="true" patchSize="12.76" fontSize="10" wrappingAllowedY="true" width="425" tickCounterLabel="ticks" maxPycor="16" updateMode="0" maxPxcor="16" minPxcor="-16"></view>
    <slider x="10" step="1" y="5" max="10" width="150" display="num-attackers" height="50" min="1" direction="Horizontal" default="5.0" variable="num-attackers"></slider>
    <slider x="175" step="1" y="5" max="6" width="150" display="num-defenders" height="50" min="1" direction="Horizontal" default="6.0" variable="num-defenders"></slider>
    <slider x="5" step="1" y="66" max="10" width="150" display="attack-rate" height="50" min="1" direction="Horizontal" default="10.0" variable="attack-rate"></slider>
    <slider x="175" step="1" y="60" max="2.0" width="150" display="move-speed" height="50" min="0.1" direction="Horizontal" default="2.0" variable="move-speed"></slider>
    <slider x="5" step="1" y="130" max="100" width="155" display="ids-accuracy" height="50" min="0" direction="Horizontal" default="90.0" variable="ids-accuracy"></slider>
    <monitor x="115" precision="17" y="255" height="60" fontSize="11" width="100" display="Attacks Blocked">attacks-blocked</monitor>
