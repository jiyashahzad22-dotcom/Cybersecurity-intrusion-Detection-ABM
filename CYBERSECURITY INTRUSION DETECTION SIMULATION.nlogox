        <update>plot attacks-breached</update>
      </pen>
    </plot>
    <plot x="820" autoPlotX="true" yMax="50.0" autoPlotY="true" y="185" xMin="0.0" height="195" legend="true" xMax="200.0" yMin="0.0" width="525" display="Real-Time Threat Analytics">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Bot Traffic" color="-14454117" legend="true">
        <setup></setup>
